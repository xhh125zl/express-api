{
    "name": "kode/express-api",
    "description": "一个通用的快递API集成包，支持多种快递公司（EMS、韵达、申通、中通、菜鸟、顺丰等）",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Kode Team",
            "email": "support@kode.com"
        }
    ],
    "require": {
        "php": "^7.4|^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "squizlabs/php_codesniffer": "^3.6"
    },
    "autoload": {
        "psr-4": {
            "Kode\\ExpressApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kode\\ExpressApi\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs-check": "phpcs --standard=PSR12 src/ tests/",
        "cs-fix": "phpcbf --standard=PSR12 src/ tests/"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}